# Configuración de ClimaCan - Archivo de ejemplo
# Copia este archivo como .env y rellena con tus credenciales

# API Tokens
# Token de AEMET - Obtener en https://opendata.aemet.es/centrodedescargas/inicio
AEMET_TOKEN=tu_token_aemet_aqui

# Token de Grafcan - Obtener en el portal de Grafcan
GRAFCAN_TOKEN=tu_token_grafcan_aqui

# Telegram (opcional - para notificaciones y alertas)
TELEGRAM_TOKEN=tu_token_bot_telegram_aqui
TELEGRAM_CHAT_ID=tu_chat_id_telegram_aqui

# InfluxDB Configuration
INFLUXDB_PORT=8096

# PostgreSQL Configuration
POSTGRES_DB=my_db
POSTGRES_USER=my_user
POSTGRES_PASSWORD=tu_contraseña_segura_aqui
POSTGRES_PORT=5435

# Grafana Configuration
GRAFANA_PORT=3010
